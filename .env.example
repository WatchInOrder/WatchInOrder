# WatchInOrder — Environment Variables
# Copy this file to .env.local and fill in real values
# NEVER commit .env.local to GitHub — it's in .gitignore

# ─── STRIPE ────────────────────────────────────────────────
# Get from: stripe.com/dashboard/apikeys
STRIPE_SECRET_KEY=sk_live_YOUR_SECRET_KEY_HERE
STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_PUBLISHABLE_KEY_HERE

# Get from: stripe.com/dashboard/webhooks (after creating webhook endpoint)
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# Your Stripe Price IDs (create products first)
STRIPE_MONTHLY_PRICE_ID=price_YOUR_MONTHLY_PRICE_ID
STRIPE_ANNUAL_PRICE_ID=price_YOUR_ANNUAL_PRICE_ID

# ─── CONVERTKIT ────────────────────────────────────────────
# Get from: app.convertkit.com/account/edit
CONVERTKIT_API_KEY=YOUR_CONVERTKIT_API_KEY
CONVERTKIT_FORM_ID=YOUR_FORM_ID

# ─── SITE ──────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://watchinorder.com

# ─── SUPABASE (when you're ready to add a real backend) ────
# Get from: supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ─── TMDB (for real movie posters) ─────────────────────────
# Get from: themoviedb.org/settings/api (free)
TMDB_API_KEY=YOUR_TMDB_API_KEY

# ─── GOOGLE ANALYTICS ──────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
